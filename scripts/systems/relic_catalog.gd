	var value: Variant = RELICS.get(id, {}).get("pool_tags", [])
	if value is Array:
		for item in value:
			result.append(str(item))
	return result

static func has_pool_tag(id: String, tag: String) -> bool:
	return pool_tags(id).has(tag)

static func shop_ids() -> Array[String]:
	var result: Array[String] = []
	for id in REWARD_ORDER:
		if runtime_allowed(id) and has_pool_tag(id, "shop"):
			result.append(id)
	return result

static func reward_ids(source_pool_filter: String = SOURCE_BASIC) -> Array[String]:
	var result: Array[String] = []
	for id in REWARD_ORDER:
		if runtime_allowed(id) and has_pool_tag(id, "reward") and source_pool(id) == source_pool_filter:
			result.append(id)
	return result

static func hooks(id: String) -> Array[String]:
	var result: Array[String] = []
	var value: Variant = RELICS.get(id, {}).get("hooks", [])
	if value is Array:
		for item in value:
			result.append(str(item))
	return result

static func display_names(ids: Array, limit: int = 2) -> String:
	var names: Array[String] = []
	for id in ids:
		names.append(display_name(str(id)))
		if names.size() >= limit:
			break
	if names.is_empty():
		return "none"
	var extra: int = max(0, ids.size() - names.size())
	return ", ".join(names) + (" +" + str(extra) if extra > 0 else "")

static func all_ids() -> Array[String]:
	return REWARD_ORDER.duplicate()

static func next_reward_id(existing_ids: Array) -> String:
	var ids := reward_ids(SOURCE_BASIC)
	for id in ids:
		if not existing_ids.has(id):
			return id
	return ids[0] if not ids.is_empty() else ""
