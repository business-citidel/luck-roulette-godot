static func get_relic(id: String) -> Dictionary:
	var relic: Dictionary = RELICS.get(id, {}).duplicate(true)
	if relic.is_empty():
		return relic
	var relic_id := str(relic.get("id", id))
	var image_id := icon_id(relic_id)
	var implemented := implementation_status(relic_id) == "runtime"
	var has_runtime_visual := ContentMetadata.runtime_relic_visual_ready(image_id)
	var asset_state := asset_status(relic_id)
	var visual_ready := has_runtime_visual or asset_state == "runtime_icon" or asset_state == "mini_icon"
	var unlocked := implemented and source_pool(relic_id) != SOURCE_EXPERIMENTAL
	return ContentMetadata.apply(relic, ContentMetadata.build(
		relic_id,
		image_id,
		implemented,
		unlocked,
		visual_ready,
		rarity(relic_id),
		pool_tags(relic_id)
	))

static func has_relic(id: String) -> bool:
	return RELICS.has(id)

static func display_name(id: String) -> String:
	if UiText.current_locale() == "ko" and RELIC_KO_NAMES.has(id):
		return str(RELIC_KO_NAMES[id])
	return DisplayBridge.display_name(id, "relic", str(RELICS.get(id, {}).get("name", id)))

static func short_description(id: String) -> String:
	if UiText.current_locale() == "ko" and RELIC_KO_DESCRIPTIONS.has(id):
		return str(RELIC_KO_DESCRIPTIONS[id])
	return DisplayBridge.description(id, "relic", str(RELICS.get(id, {}).get("description", "")))

static func icon_id(id: String) -> String:
	return DisplayBridge.icon_id(id, "relic", str(RELICS.get(id, {}).get("icon_id", id)))

static func shop_price(id: String) -> int:
	return DisplayBridge.shop_price(id, "relic", int(RELICS.get(id, {}).get("shop_price", 30)))

static func rarity(id: String) -> String:
	return DisplayBridge.rarity(id, "relic", str(RELICS.get(id, {}).get("rarity", "common")))

static func source_pool(id: String) -> String:
	return str(RELICS.get(id, {}).get("source_pool", SOURCE_BASIC))

static func core_tags(id: String) -> Array[String]:
